NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://mi_turno_user:mi_turno_pass@postgres:5432/mi_turno

BAILEYS_AUTH_DIR=auth_info_baileys
BAILEYS_AUTO_CONNECT=false

REMINDER_WORKER_ENABLED=true
REMINDER_LEAD_MINUTES=120
REMINDER_POLL_INTERVAL_MS=15000
REMINDER_BATCH_SIZE=20
REMINDER_MAX_ATTEMPTS=3
